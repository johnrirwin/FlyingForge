# Server environment variables

# HTTP server address
HTTP_ADDR=:8080

# Run in MCP stdio mode (set to true for MCP server mode)
MCP_MODE=false

# Public HTTPS base URL for the HTTP MCP endpoint (used for ChatGPT connector metadata)
MCP_PUBLIC_BASE_URL=https://your-public-host.example.com

# Allowed browser origins for the HTTP MCP endpoint
MCP_ALLOWED_ORIGINS=https://chatgpt.com,https://chat.openai.com

# OAuth/OIDC settings for private MCP tools
# For self-hosted OAuth, set MCP_AUTH_SELF_HOSTED=true and point MCP_AUTH_ISSUER
# at this app's public HTTPS base URL.
MCP_AUTH_SELF_HOSTED=false
MCP_AUTH_ISSUER=
MCP_AUTH_AUDIENCE=
# Optional: override the protected resource identifier; defaults to MCP_PUBLIC_BASE_URL + /mcp
MCP_AUTH_RESOURCE=
# Optional: comma-separated scopes required for private MCP tools
MCP_AUTH_SCOPES=flyingforge.read
# Optional discovery / JWKS overrides
MCP_AUTH_DISCOVERY_URL=
MCP_AUTH_JWKS_URL=
# Optional dev/test escape hatch for self-hosted OAuth when no private key is configured.
MCP_AUTH_ALLOW_EPHEMERAL_KEY=false
# Self-hosted OAuth signing + browser login settings
MCP_AUTH_PRIVATE_KEY_PEM=
MCP_AUTH_KEY_ID=ff-self-hosted
MCP_AUTH_GOOGLE_REDIRECT_URI=https://your-public-host.example.com/oauth/google/callback
MCP_AUTH_ACCESS_TOKEN_TTL=1h
MCP_AUTH_CODE_TTL=10m
MCP_AUTH_REFRESH_TOKEN_TTL=720h
MCP_AUTH_SESSION_TTL=24h

# Cache backend: "memory" or "redis"
CACHE_BACKEND=memory

# Cache TTL for feed items (e.g., 5m, 10m, 1h)
CACHE_TTL=5m

# Redis server address (only used when CACHE_BACKEND=redis)
REDIS_ADDR=localhost:6379

# Minimum delay between requests to same host
RATE_LIMIT=1s

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# CORS allowed origin (use * for all, or specific origin like http://localhost:5173)
CORS_ORIGIN=*

# Reddit API credentials (optional - uses public JSON endpoints by default)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# Google OAuth (required for Google SSO login)
AUTH_JWT_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Image moderation (Amazon Rekognition)
IMAGE_MODERATION_ENABLED=true
AWS_REGION=us-east-1
# Optional locally: AWS_PROFILE=dev
MODERATION_REJECT_CONFIDENCE=70
MODERATION_TIMEOUT=5s
MODERATION_PENDING_TTL=10m
